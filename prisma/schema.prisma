generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String
  price         Float
  comparePrice  Float?
  images        String[]
  scent         String
  size          String[]
  burnTime      String
  ingredients   String
  howToUse      String
  stock         Int         @default(100)
  featured      Boolean     @default(false)
  bestseller    Boolean     @default(false)
  isNew         Boolean     @default(false)
  collectionId  String?
  collection    Collection? @relation(fields: [collectionId], references: [id])
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  createdAt     DateTime    @default(now())
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  image       String
  products    Product[]
}

model Order {
  id          String      @id @default(cuid())
  email       String
  firstName   String
  lastName    String
  address     String
  city        String
  postcode    String
  country     String
  phone       String
  total       Float
  discount    Float       @default(0)
  status      OrderStatus @default(PENDING)
  stripeId    String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  size      String
  price     Float
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String
  email     String
  rating    Int
  title     String
  body      String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model DiscountCode {
  id         String   @id @default(cuid())
  code       String   @unique
  type       String
  value      Float
  minOrder   Float    @default(0)
  usageLimit Int      @default(100)
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  active     Boolean  @default(true)
}
